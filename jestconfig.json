{
    "transform": {
        "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "testRegex": "(/__tests__/.*|(\\.|/)(test|spec))\\.(jsx?|tsx?)$",
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json", "node"],
    "collectCoverageFrom": [
        "src/**/*.ts",
        "!src/**/__tests__/**",
        "!src/types/**",
        "!src/secrets.ts"
    ],
    "coverageReporters": ["html", "text", "text-summary"],
    "coverageDirectory": "coverage"
}