{
  "name": "@rilog-development/rilog-lib",
  "version": "0.6.7",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Andrii Karnaukh <kaowebdev@gmail.com>",
  "license": "MIT",
  "scripts": {
    "test": "jest --config jestconfig.json",
    "build": "node scripts/generate-secrets.js && tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "tslint -p tsconfig.json",
    "prepare": "npm run build && husky",
    "prepublishOnly": "npm run lint",
    "version": "npm run format && changelogen && git add -A src CHANGELOG.md",
    "postversion": "git push && git push --tags",
    "minor": "npm version minor",
    "patch": "npm version patch",
    "release": "npm publish --access public"
  },
  "files": [
    "dist/**/*"
  ],
  "keywords": [
    "rilog",
    "frontend logger monitoring",
    "logger",
    "debugger",
    "frontend debugger",
    "axios",
    "axios logger",
    "axios debugger",
    "react",
    "react logger",
    "react-logger"
  ],
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.1",
    "@types/react": "^18.3.28",
    "changelogen": "^0.6.2",
    "husky": "9.1.7",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.0",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rilog-development/rilog-lib.git#main"
  }
}
